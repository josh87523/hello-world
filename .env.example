# ============================================
# 自媒体 AI 工作流 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ---------- AI 模型配置（Anthropic Claude） ----------
ANTHROPIC_API_KEY=sk-ant-your-api-key
AI_MODEL=claude-sonnet-4-20250514

# ---------- 飞书配置 ----------
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_FOLDER_TOKEN=your-folder-token
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# ---------- 工作流配置 ----------
CONTENT_DOMAINS=ai,创业,写作
PLATFORM=xiaohongshu
DAILY_COUNT=1
SCHEDULE_TIME=08:00
QUALITY_THRESHOLD=0.75

# ---------- 矩阵号配置 ----------
MATRIX_ENABLED=false
MATRIX_STATE_FILE=data/matrix_state.json
ANALYTICS_FILE=data/analytics.json
COVER_VARIANTS=3

# ---------- 数据爬取与对标分析 ----------
# 从浏览器开发者工具中复制小红书的Cookie（Network tab -> 任意请求 -> Cookie header）
XHS_COOKIE=
XHS_RATE_LIMIT=2.0
XHS_MAX_SEARCH=40
XHS_MAX_USER_NOTES=50
XHS_DATA_DIR=data/scraper
BENCHMARK_FILE=data/benchmark.json
